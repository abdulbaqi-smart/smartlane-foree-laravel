{
    "name": "abdulbaqi-smart/smartlane-foree-laravel",
    "description": "Laravel package for Foree Bill Payment Gateway (foreebill.com)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Smartlane",
            "email": "support@smartlane.pk"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/events": "^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "smartlane\\Foree\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "smartlane\\Foree\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "smartlane\\Foree\\ForeeServiceProvider"
            ],
            "aliases": {
                "Foree": "smartlane\\Foree\\Facades\\Foree"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
